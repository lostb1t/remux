# --- Stage: pull Jellyfin web assets once (cached layer) ---
FROM jellyfin/jellyfin:10.10.7 AS web

# --- Stage: dev environment with hot reload ---
FROM rust:bookworm AS dev

ENV DEBIAN_FRONTEND=noninteractive
# System deps you mentioned (ffmpeg + headers for probing/bindings)
# RUN apt-get update && apt-get install -y --no-install-recommends \
#     curl xz-utils ca-certificates && \
#     rm -rf /var/lib/apt/lists/*
# Build deps for ffmpeg-sys-next (needs headers + pkg-config)
RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config llvm-dev libclang-dev build-essential \
    libavutil-dev libavcodec-dev libavformat-dev libavfilter-dev \
    libavdevice-dev libswscale-dev libswresample-dev libpostproc-dev \
 && LLVM_LIBDIR=$(llvm-config --libdir) \
 && ln -sf "$LLVM_LIBDIR/libclang.so" /usr/lib/libclang.so \
 && printf 'LIBCLANG_PATH=%s\n' "$LLVM_LIBDIR" >> /etc/environment \
 && rm -rf /var/lib/apt/lists/*

ARG JF_FFMPEG_VERSION=7.1.1-7
RUN set -eux; \
    . /etc/os-release; \
    ARCH="$(dpkg --print-architecture)"; \
    CODENAME="${VERSION_CODENAME}"; \
    BASE_REPO="https://repo.jellyfin.org/master/files/ffmpeg/debian/7.x/${JF_FFMPEG_VERSION}/${ARCH}"; \
    FILE_NAME="jellyfin-ffmpeg7_${JF_FFMPEG_VERSION}-${CODENAME}_${ARCH}.deb"; \
    DEB_URL="${BASE_REPO}/${FILE_NAME}"; \
    echo "Downloading: ${DEB_URL}"; \
    curl -fL --retry 3 -o /tmp/jellyfin-ffmpeg7.deb "${DEB_URL}"; \
    apt-get update; \
    apt-get install -y --no-install-recommends /tmp/jellyfin-ffmpeg7.deb; \
    ln -sf /usr/lib/jellyfin-ffmpeg/ffmpeg  /usr/local/bin/ffmpeg; \
    ln -sf /usr/lib/jellyfin-ffmpeg/ffprobe /usr/local/bin/ffprobe; \
    ffmpeg -version; \
    rm -f /tmp/jellyfin-ffmpeg7.deb

RUN cargo install cargo-make

# Workdir
WORKDIR /app

# Pre-build dependency cache (no source yet)
COPY Cargo.toml Cargo.lock ./
RUN mkdir -p src && echo "fn main() { println!(\"warm cache\"); }" > src/main.rs
RUN cargo build && rm -rf src

# Jellyfin web assets available at runtime
ENV WEB_PATH=/app/jellyfin-web
COPY --from=web /jellyfin/jellyfin-web ${WEB_PATH}

# Port your app serves on (change if needed)
EXPOSE 8080

# In dev you'll bind-mount your source; cargo-watch will rebuild & rerun
CMD ["cargo", "make", "dev"]